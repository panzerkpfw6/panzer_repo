<?xml version="1.0" encoding="UTF-8"?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6"/>
	<Project>
		<Option title="simwave_apps"/>
		<Option makefile_is_custom="1"/>
		<Option compiler="icc"/>
		<Option virtualFolders="CMake Files\;CMake Files\src\;CMake Files\app\;CMake Files\cmake\;CMake Files\cmake\modules\;"/>
		<Build>
			<Target title="all">
				<Option working_dir="/shared/simwave/simwave/app"/>
				<Option type="4"/>
				<MakeCommands>
					<Build command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 all"/>
					<CompileFile command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 &quot;$file&quot;"/>
					<Clean command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 clean"/>
					<DistClean command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 clean"/>
				</MakeCommands>
			</Target>
			<Target title="simwave_apps">
				<Option working_dir="/shared/simwave/simwave/app"/>
				<Option type="4"/>
				<MakeCommands>
					<Build command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 simwave_apps"/>
					<CompileFile command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 &quot;$file&quot;"/>
					<Clean command="/usr/bin/make -f &quot;/shared/simwave/simwave/app/Makefile&quot;  VERBOSE=1 clean"/>
